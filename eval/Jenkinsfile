pipeline {
    agent any

    environment {
        // [수정 완료] 성공적으로 생성하신 ACR 이름 적용
        ACR_NAME = 'eesregistry2026' 
        ACR_URL = "${ACR_NAME}.azurecr.io"
        IMAGE_NAME = 'ees-eval-app'
        
        // [수정 완료] 이전 단계에서 생성한 리소스 그룹 이름 적용
        RESOURCE_GROUP = 'EES-ResourceGroup'
        
        // 💡 주의: Azure Web App(웹 서버)을 아직 안 만드셨다면, 나중에 서버 생성 후 이 이름을 꼭 채워주셔야 합니다!
        APP_NAME = 'ees-eval-app-2026' 
        
        TAG = "${env.BUILD_NUMBER}"
        
        // 젠킨스 Credentials 메뉴에서 만든 ID
        AZURE_CRED_ID = 'my-azure-credential' 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                dir('eval') {
                    sh './mvnw clean package -DskipTests'
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                withCredentials([azureServicePrincipal(env.AZURE_CRED_ID)]) {
                    sh """
                        # Azure 로그인
                        az login --service-principal -u \$AZURE_CLIENT_ID -p \$AZURE_CLIENT_SECRET -t \$AZURE_TENANT_ID
                        
                        # ACR 전용 로그인 (별도 비번 필요 없음)
                        az acr login --name ${ACR_NAME}
                        
                        dir('eval') {
                            docker build -t ${ACR_URL}/${IMAGE_NAME}:${TAG} .
                            docker push ${ACR_URL}/${IMAGE_NAME}:${TAG}
                            
                            # 최신 이미지임을 알리기 위해 latest 태그도 함께 푸시 (선택 사항)
                            docker tag ${ACR_URL}/${IMAGE_NAME}:${TAG} ${ACR_URL}/${IMAGE_NAME}:latest
                            docker push ${ACR_URL}/${IMAGE_NAME}:latest
                        }
                    """
                }
            }
        }

        stage('Deploy to Azure') {
            steps {
                withCredentials([azureServicePrincipal(env.AZURE_CRED_ID)]) {
                    sh """
                        az login --service-principal -u \$AZURE_CLIENT_ID -p \$AZURE_CLIENT_SECRET -t \$AZURE_TENANT_ID
                        
                        # 웹 앱의 컨테이너 이미지 업데이트
                        az webapp config container set --name ${APP_NAME} \
                            --resource-group ${RESOURCE_GROUP} \
                            --docker-custom-image-name ${ACR_URL}/${IMAGE_NAME}:${TAG}
                    """
                }
            }
        }
    }

    // 빌드 후 정리 작업
    post {
        success {
            echo '배포가 성공적으로 완료되었습니다!'
        }
        always {
            // 젠킨스 서버의 디스크 용량 확보를 위해 로컬에 생성된 이미지는 삭제
            sh "docker rmi ${ACR_URL}/${IMAGE_NAME}:${TAG} || true"
            cleanWs()
        }
    }
}